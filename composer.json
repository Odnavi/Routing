{
    "name": "odnavi/routing",
    "description": "Атрибутный роутинг: #[Route], сканер контроллеров (ClassScanner) и фабрика маршрутов (RouteFactory) с кэшем route_map.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ivan Parfentev"
        }
    ],
    "require": {
        "php": ">=8.2",
        "odnavi/core": "^1.0",
        "symfony/validator": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "Odnavi\\Routing\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
